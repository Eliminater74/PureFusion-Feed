{
  "manifest_version": 3,
  "name": "PureFusion Feed",
  "version": "1.0.0",
  "description": "Your Facebook. Filtered. Predicted. Perfected.",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "*://*.facebook.com/*",
    "*://*.messenger.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*"
      ],
      "css": [
        "src/styles/injected.css"
      ],
      "js": [
        "src/utils/logger.js",
        "src/utils/helpers.js",
        "src/utils/storage.js",
        "src/data/default-settings.js",
        "src/data/selector-map.js",
        "src/content/observer.js",
        "src/content/cleaner.js",
        "src/content/predictor.js",
        "src/content/feed-manager.js",
        "src/content/ui-tweaks.js",
        "src/content/social-tools.js",
        "src/content/notifications.js",
        "src/content/wellbeing.js",
        "src/content/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
